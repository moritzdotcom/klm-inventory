generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String

  inventories Inventory[]
  sessions    Session[]

  waiterIssueLogs   EventWaiterIssueLog[]
  employeeDrinkLogs EventEmployeeDrinkLog[]
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Invite {
  id    String @id @default(uuid())
  email String @unique
}

model Event {
  id   String   @id @default(uuid())
  name String
  date DateTime

  /**
   * Abrechnung des Tischkellners inklusive Umsatz.
   */
  settlement EventSettlement?

  /**
   * Anfangsbestand, Endbestand und Mitarbeitergetränke
   * für dieses Event.
   */
  inventory EventInventory?
}

model Item {
  id       String       @id @default(uuid())
  category ItemCategory
  brandId  String
  brand    Brand        @relation(fields: [brandId], references: [id], onDelete: Cascade)
  name     String

  /**
   * Für physische Gebinde: Flaschen- oder Bag-Größe.
   * Für abstrakte Verkaufsprodukte wie "Aperol Boot" oder
   * "10 × Estrella Bucket" kann das Feld leer bleiben.
   */
  sizeInMl Int?

  image          String @default("")
  amountInStock  Int    @default(0)
  amountPerCrate Int    @default(1)
  priceCents     Int    @default(0)

  inventoryEnabled Boolean @default(true)
  waiterEnabled    Boolean @default(true)

  /**
   * Freie, eventunabhängige Lagerinventuren.
   */
  countings Counting[]

  /**
   * Eventbezogene Kühlwagen-Zählungen:
   * Anfangs- und Endbestand.
   */
  eventInventoryCountings EventInventoryCounting[]

  /**
   * Mitarbeitergetränke.
   */
  employeeDrinkIssues EventEmployeeDrinkIssue[]
  employeeDrinkLogs   EventEmployeeDrinkLog[]

  waiterIssues    EventWaiterIssue[]
  waiterIssueLogs EventWaiterIssueLog[]

  recipeComponents ItemRecipeComponent[] @relation("RecipeParent")
  usedInRecipes    ItemRecipeComponent[] @relation("RecipeIngredient")

  waiterIssueRecipeComponents EventWaiterIssueRecipeComponent[]
}

enum ItemCategory {
  WATER
  SOFTDRINK
  BEER
  WINE
  CHAMPAGNE
  LIQUOR
  SPECIALS
}

model ItemRecipeComponent {
  id String @id @default(uuid())

  parentItemId String
  parentItem   Item   @relation("RecipeParent", fields: [parentItemId], references: [id], onDelete: Cascade)

  ingredientItemId String
  ingredientItem   Item   @relation("RecipeIngredient", fields: [ingredientItemId], references: [id], onDelete: Restrict)

  /**
   * Immer eine positive Ganzzahl:
   * 3 UNIT        = 3 Flaschen Secco
   * 40 MILLILITER = 4 cl Lillet
   */
  amount Int
  unit   RecipeUnit

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([parentItemId, ingredientItemId])
  @@index([ingredientItemId])
}

enum RecipeUnit {
  UNIT
  MILLILITER
}

/**
 * Eine frei erstellbare Lagerinventur.
 * Beispiele:
 * - Hauptlager vor dem Wochenende
 * - Kühlwagen nach Event-Rückkehr
 * - Monatsinventur
 * Diese Inventur ist nicht zwingend einem Event zugeordnet.
 */
model Inventory {
  id String @id @default(uuid())

  label String?
  note  String?

  creatorId String
  creator   User   @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  countings Counting[]

  done      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Counting {
  id String @id @default(uuid())

  amount Int

  itemId String
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  inventoryId String
  inventory   Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  @@unique([itemId, inventoryId])
  @@index([inventoryId])
}

model Brand {
  id    String @id @default(uuid())
  name  String @unique
  items Item[]
}

/**
 * Abrechnung eines Events mit dem Tischkellner.
 * Aktuell gibt es genau eine Abrechnung pro Event.
 * Falls ihr später mehrere Kellner getrennt abrechnen möchtet,
 * kann die @unique-Constraint auf eventId entfernt werden.
 */
model EventSettlement {
  id      String @id @default(uuid())
  eventId String @unique
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  waiterName               String?
  prepaidMinimumSpendCents Int     @default(0)

  // Einnahmen, die der Tischkellner nach dem Event meldet
  cashRevenueCents Int @default(0)
  cardRevenueCents Int @default(0)

  /**
   * Tatsächlich gemeldete Einnahmen der offenen Theke.
   */
  openBarCashRevenueCents Int @default(0)
  openBarCardRevenueCents Int @default(0)

  /**
   * Freitext für Auffälligkeiten oder Hinweise zur Abrechnung.
   */
  analysisNote String?

  closedAt DateTime?

  issues EventWaiterIssue[]
  logs   EventWaiterIssueLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/**
 * Aktueller Gesamtzähler pro Artikel.
 * Der Preis wird beim ersten Herausgeben als Snapshot gespeichert.
 * Ändert sich der Artikelpreis später, bleiben ältere Event-Abrechnungen
 * dadurch unverändert.
 */
model EventWaiterIssue {
  id           String          @id @default(uuid())
  settlementId String
  settlement   EventSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  itemId String
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Restrict)

  quantity       Int     @default(0)
  unitPriceCents Int
  hidden         Boolean @default(false)

  recipeSnapshotCreatedAt DateTime?
  recipeSnapshot          EventWaiterIssueRecipeComponent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([settlementId, itemId])
}

model EventWaiterIssueRecipeComponent {
  id String @id @default(uuid())

  issueId String
  issue   EventWaiterIssue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  ingredientItemId String
  ingredientItem   Item   @relation(fields: [ingredientItemId], references: [id], onDelete: Restrict)

  amount Int
  unit   RecipeUnit

  createdAt DateTime @default(now())

  @@unique([issueId, ingredientItemId, unit])
  @@index([ingredientItemId])
}

/**
 * Unveränderliches Änderungsprotokoll.
 * quantityDelta kann beispielsweise 1, 6, 12 oder -1 sein.
 * Negative Werte sind Korrekturen.
 */
model EventWaiterIssueLog {
  id           String          @id @default(uuid())
  settlementId String
  settlement   EventSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  itemId String
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  creatorId String
  creator   User   @relation(fields: [creatorId], references: [id], onDelete: Restrict)

  quantityDelta  Int
  unitPriceCents Int
  createdAt      DateTime @default(now())

  @@index([settlementId, createdAt])
}

/**
 * Bestandsführung für genau ein Event.
 * Enthält:
 * - Kühlwagen-Anfangsbestand
 * - Kühlwagen-Endbestand
 * - Mitarbeitergetränke
 * Die Tischkellner-Ausgaben liegen weiterhin separat
 * im EventSettlement.
 */
model EventInventory {
  id String @id @default(uuid())

  eventId String @unique
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  countings EventInventoryCounting[]

  employeeDrinkIssues EventEmployeeDrinkIssue[]
  employeeDrinkLogs   EventEmployeeDrinkLog[]

  openingCompletedAt        DateTime?
  employeeDrinksCompletedAt DateTime?
  closingCompletedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum EventInventoryCountingPhase {
  OPENING
  CLOSING
}

/**
 * Gezählte Gebinde im Kühlwagen zu Beginn oder Ende eines Events.
 * Ein Item darf pro Event und Phase nur einmal vorkommen.
 */
model EventInventoryCounting {
  id String @id @default(uuid())

  eventInventoryId String
  eventInventory   EventInventory @relation(fields: [eventInventoryId], references: [id], onDelete: Cascade)

  itemId String
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Restrict)

  phase  EventInventoryCountingPhase
  amount Int                         @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventInventoryId, itemId, phase])
  @@index([itemId])
}

/**
 * Aktuelle Gesamtsumme der Mitarbeitergetränke pro Artikel.
 * Beispiel:
 * - 14 × Estrella
 * - 8 × Wasser Still
 * - 3 × Fritz-Kola
 */
model EventEmployeeDrinkIssue {
  id String @id @default(uuid())

  eventInventoryId String
  eventInventory   EventInventory @relation(fields: [eventInventoryId], references: [id], onDelete: Cascade)

  itemId String
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Restrict)

  quantity Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventInventoryId, itemId])
  @@index([itemId])
}

/**
 * Unveränderliches Änderungsprotokoll für Mitarbeitergetränke.
 * quantityDelta kann beispielsweise 1, 6, 12 oder -1 sein.
 */
model EventEmployeeDrinkLog {
  id String @id @default(uuid())

  eventInventoryId String
  eventInventory   EventInventory @relation(fields: [eventInventoryId], references: [id], onDelete: Cascade)

  itemId String
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Restrict)

  creatorId String
  creator   User   @relation(fields: [creatorId], references: [id], onDelete: Restrict)

  quantityDelta Int
  createdAt     DateTime @default(now())

  @@index([eventInventoryId, createdAt])
  @@index([itemId])
}
